{
  "manifest_version": 2,
  "name": "Social Media Post Formatter",
  "version": "1.1",
  "description": "Copies a formatted social media site post string to clipboard.",

  "icons": {
    "48": "icon.png"
  },

  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "Copy Post Info",
    "default_popup": "popup.html"
  },

  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.bsky.app/*",
        "*://*.reddit.com/*",
        "*://*.old.reddit.com/*",
        "*://twitter.com/*",
        "*://x.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
